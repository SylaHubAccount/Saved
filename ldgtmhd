task.spawn(function()
    while task.wait() do
        if Config.AutoFarm then
            local stats = LP:WaitForChild("leaderstats", 5)
            local coinValue = stats and stats:FindFirstChild("VerifiedCoins")
            
            local ignored = workspace:FindFirstChild("Ignored")
            if ignored then
                local coinsFolder = ignored:FindFirstChild("VerifiedCoins_Giver")
                local doorsFolder = ignored:FindFirstChild("TeleportDoors")
                
                if coinsFolder and doorsFolder then
                    local coinFound = false
                    
                    for i = 1, 5 do
                        if not Config.AutoFarm then break end
                        local coinPart = coinsFolder:FindFirstChild("VerifiedCoin_TouchPart" .. i)
                        
                        if coinPart then
                            coinFound = true
                            local oldCoins = coinValue and coinValue.Value or 0
                            
                            if LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                                LP.Character.HumanoidRootPart.CFrame = coinPart.CFrame
                            end
                            
                            task.wait(1.5)
                            
                            local newCoins = coinValue and coinValue.Value or 0
                            
                            if newCoins <= oldCoins and Config.AutoExecute then
                                ServerHop("No more coins found, rejoining...")
                                return
                            end
                        end
                    end

                    if not coinFound and Config.AutoFarm then
                        local door1 = doorsFolder:FindFirstChild("TeleportObby_1")
                        local door2 = doorsFolder:FindFirstChild("TeleportObby_2")
                        
                        if door1 and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                            LP.Character.HumanoidRootPart.CFrame = door1.CFrame
                        end
                        task.wait(1)
                        if door2 and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
                            LP.Character.HumanoidRootPart.CFrame = door2.CFrame
                        end
                        task.wait(1)
                    end
                end
            end
        end
    end
end)

